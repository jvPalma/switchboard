{
  "name": "switchboard",
  "version": "0.0.11",
  "private": true,
  "description": "A desktop app for browsing, searching, and managing CLI coding sessions",
  "author": "Doctly <support@doctly.ai>",
  "main": "dist/main.js",
  "scripts": {
    "start": "node scripts/build.js all && electron .",
    "start:web": "node scripts/build.js all && node dist/web.js",
    "dev": "node scripts/dev.js",
    "electron": "electron .",
    "build:main": "node scripts/build.js main",
    "build:preload": "node scripts/build.js preload",
    "build:renderer": "node scripts/build.js renderer",
    "build:web": "node scripts/build.js web",
    "build:worker": "node scripts/build.js worker",
    "build:all": "node scripts/build.js all",
    "bundle:codemirror": "node scripts/build.js codemirror",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "node --test",
    "generate-icons": "node scripts/generate-icons.js && node scripts/generate-dmg-background.js",
    "build": "node scripts/build.js all && electron-builder",
    "build:mac": "node scripts/build.js all && electron-builder --mac && node scripts/postinstall.js && codesign --sign - --force --deep dist/mac-arm64/Switchboard.app 2>/dev/null; true",
    "build:mac:arm64": "electron-builder --mac --arm64 2>/dev/null; true",
    "build:win": "node scripts/build.js all && electron-builder --win",
    "build:linux": "node scripts/build.js all && electron-builder --linux",
    "release": "node scripts/build.js all && electron-builder --publish always",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@ddietr/codemirror-themes": "^1.5.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.0.0",
    "codemirror": "^6.0.2",
    "electron-log": "^5.3.0",
    "electron-updater": "^6.3.0",
    "express": "^4.22.1",
    "marked": "^17.0.4",
    "morphdom": "^2.7.8",
    "node-pty": "^1.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.62",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-reloader": "^1.2.3",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "png2icons": "^2.0.1",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "ai.doctly.switchboard",
    "productName": "Switchboard",
    "files": [
      "dist/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/node-pty/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "doctly",
      "repo": "switchboard"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Development"
    },
    "dmg": {
      "background": "build/dmg-background.png",
      "iconSize": 100,
      "window": {
        "width": 660,
        "height": 400
      },
      "contents": [
        {
          "x": 170,
          "y": 170
        },
        {
          "x": 490,
          "y": 170,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
