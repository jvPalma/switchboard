{
  "name": "switchboard",
  "version": "0.0.5",
  "private": true,
  "description": "A desktop app for browsing, searching, and managing CLI coding sessions",
  "author": "Doctly <support@doctly.ai>",
  "main": "main.js",
  "scripts": {
    "start": "npm run bundle:codemirror && electron .",
    "electron": "electron .",
    "bundle:codemirror": "esbuild public/codemirror-setup.js --bundle --outfile=public/codemirror-bundle.js --format=iife --platform=browser --minify",
    "generate-icons": "node scripts/generate-icons.js && node scripts/generate-dmg-background.js",
    "build": "npm run bundle:codemirror && electron-builder",
    "build:mac": "npm run bundle:codemirror && electron-builder --mac && node scripts/postinstall.js && codesign --sign - --force --deep dist/mac-arm64/Switchboard.app 2>/dev/null; true",
    "build:win": "npm run bundle:codemirror && electron-builder --win",
    "build:linux": "npm run bundle:codemirror && electron-builder --linux",
    "release": "npm run bundle:codemirror && electron-builder --publish always",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@ddietr/codemirror-themes": "^1.5.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.0.0",
    "codemirror": "^6.0.2",
    "electron-log": "^5.3.0",
    "electron-updater": "^6.3.0",
    "express": "^4.21.0",
    "morphdom": "^2.7.8",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.62",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-reloader": "^1.2.3",
    "esbuild": "^0.27.3",
    "png2icons": "^2.0.1"
  },
  "build": {
    "appId": "ai.doctly.switchboard",
    "productName": "Switchboard",
    "files": [
      "main.js",
      "preload.js",
      "db.js",
      "workers/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/node-pty/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "doctly",
      "repo": "switchboard"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Development"
    },
    "dmg": {
      "background": "build/dmg-background.png",
      "iconSize": 100,
      "window": {
        "width": 660,
        "height": 400
      },
      "contents": [
        {
          "x": 170,
          "y": 170
        },
        {
          "x": 490,
          "y": 170,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
